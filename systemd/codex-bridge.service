[Unit]
Description=Codex Bridge (FastAPI)
After=network.target ollama.service
Wants=network.target

[Service]
Type=simple
User=nexus
WorkingDirectory=/home/nexus/codex-bridge
EnvironmentFile=/home/nexus/codex-bridge/.env
ExecStart=/home/nexus/codex-bridge/.venv/bin/uvicorn app.main:app --host 0.0.0.0 --port 8787
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
